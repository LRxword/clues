<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>cluesmash experimental</title>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>

<style>
:root{
  --bg:#14151d;
  --card:#fff9ec;
  --blue:#8bd8ff;
  --pink:#ffacd4;
  --mint:#baf7d1;
  --yellow:#fff09b;
  --red:#ffb4b4;
}
*{box-sizing:border-box}
body{
  margin:0;
  min-height:100dvh;
  background:
    radial-gradient(circle at 12% 10%,#8bd8ff55,transparent 28%),
    radial-gradient(circle at 88% 16%,#ffacd455,transparent 28%),
    radial-gradient(circle at 52% 95%,#baf7d144,transparent 34%),
    var(--bg);
  font-family:Montserrat,sans-serif;
  color:#fff;
  padding:18px 14px 100px;
}

.wrap{max-width:900px;margin:auto;display:grid;gap:12px}

.card{
  background:var(--card);
  color:#111;
  border:3px solid #000;
  border-radius:28px;
  box-shadow:8px 8px 0 #000;
  padding:20px;
}

.clue{
  font-size:1.6rem;
  font-weight:900;
  margin-bottom:16px;
}

.answer{
  background:#111;
  color:#111;
  padding:12px;
  border-radius:14px;
  border:3px solid #000;
  letter-spacing:0.2em;
}

.answer.show{background:var(--yellow);color:#111;letter-spacing:normal}
.answer.hint{background:#fff;color:#2a5fd7;letter-spacing:normal}

.actions{
  display:flex;
  gap:10px;
  margin-top:16px;
}

button{
  flex:1;
  padding:12px;
  font-weight:900;
  border:2px solid #000;
  box-shadow:3px 3px 0 #000;
}

.no{background:var(--red)}
.workshop{background:var(--yellow)}
.perfect{background:var(--mint)}

textarea{
  width:100%;
  margin-top:10px;
  padding:10px;
  border:3px solid #000;
  border-radius:12px;
}

</style>
</head>

<body>

<div class="wrap">
  <div class="card" id="card">
    <div class="clue">Loading…</div>
    <div class="answer" id="answer"></div>

    <div class="actions">
      <button class="no" onclick="rate('No')">❌</button>
      <button class="workshop" onclick="rate('Workshop')">💡</button>
      <button class="perfect" onclick="rate('Perfect')">⭐</button>
    </div>

    <textarea id="note" placeholder="Note..."></textarea>
  </div>
</div>

<script>
const SHEET_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vSsSUD7PgliCuhNkFFA3nyjes14LHlg1Gp2wuLlG5DU6FIp4CwP0lbrmGLuGe_DlhlbdM6fh_xwb2sZ/pub?output=csv";

let clues = [];
let i = 0;
let reveal = 0;

function mask(a){
  return a.replace(/[A-Za-z]/g,"█");
}

function hintText(raw){
  try{
    let p = JSON.parse(raw);
    return p.map(x=>x.text).join("\n\n");
  }catch{return raw;}
}

async function load(){
  let res = await fetch(SHEET_URL);
  let txt = await res.text();
  let data = Papa.parse(txt,{header:true}).data;

  clues = data.filter(x=>x.clue && x.answer);
  show();
}

function show(){
  let c = clues[i];
  document.querySelector(".clue").innerText = c.clue;
  document.getElementById("answer").innerText = mask(c.answer);
  document.getElementById("note").value = "";
  reveal = 0;
}

document.getElementById("answer").onclick = ()=>{
  let c = clues[i];

  if(reveal===0 && c.hints){
    document.getElementById("answer").className="answer hint";
    document.getElementById("answer").innerText = hintText(c.hints);
    reveal=1;
  }
  else if(reveal<2){
    document.getElementById("answer").className="answer show";
    document.getElementById("answer").innerText = c.answer;
    reveal=2;
  }
  else{
    document.getElementById("answer").className="answer";
    document.getElementById("answer").innerText = mask(c.answer);
    reveal=0;
  }
};

function rate(type){
  i++;
  if(i>=clues.length) i=0;
  show();
}

load();
</script>

</body>
</html>